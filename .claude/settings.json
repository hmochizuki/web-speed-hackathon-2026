{
  "permissions": {
    "allow": [
      "Bash(cd * && pnpm *)",
      "Bash(cd * && ANALYZE=* pnpm *)",
      "Bash(cd * && PORT=* pnpm *)",
      "Bash(cd * && E2E_BASE_URL=* pnpm *)",
      "Bash(PORT=* pnpm *)",
      "Bash(E2E_BASE_URL=* pnpm *)",
      "Bash(ANALYZE=* pnpm *)",
      "Bash(curl *)",
      "Bash(lsof *)",
      "Bash(kill *)",
      "Bash(ffmpeg *)",
      "Bash(du *)",
      "Bash(sqlite3 *)",
      "Skill(implement-task)",
      "Skill(check-regulation)",
      "Skill(check-bundle-size)",
      "Skill(code-review:code-review)",
      "Skill(update-config)",
      "Read(*/web-speed-hackathon-2026/*)",
      "Bash(cp */temp/backup-jpg/e2e-initial-commit-snapshots/* *)",
      "Bash(gh issue comment *)",
      "Bash(gh api *)",
      "Bash(gh pr *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git worktree *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Skill(run-scoring)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -q 'git commit' && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"コミット前にレギュレーション違反チェック（静的チェックのみ）を実行してください。Agent ツールで check-regulation subagent を起動し、チェック1〜5（fly.toml、シードID、SSEプロトコル、crok情報伝達、手動テスト項目の機能保持）の結果を確認してからコミットしてください。VRT（チェック6）はスキップしてください。違反がある場合はコミットを中止し、修正を提案してください。\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -q 'git commit' && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"コミットが実行されました。temp/todo_list.md の該当タスクのステータスに更新漏れがないか確認し、必要に応じて更新してください。\"}}' || true"
          }
        ]
      }
    ]
  }
}
